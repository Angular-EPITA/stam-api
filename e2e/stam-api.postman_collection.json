          "mode": "raw",
          "raw": "{\"title\":\"E2E Test Game Updated\",\"description\":\"Updated by Newman\",\"releaseDate\":\"2025-07-01\",\"price\":39.99,\"imageUrl\":\"https://example.com/e2e-updated.png\",\"genreId\":2}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update game returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Game title is updated', function () {",
              "  var json = pm.response.json();",
              "  pm.expect(json.title).to.eql('E2E Test Game Updated');",
              "  pm.expect(json.price).to.eql(39.99);",
              "});"
            ]
          }
        }
      ]
    },
